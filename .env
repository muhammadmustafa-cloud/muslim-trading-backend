# Server
NODE_ENV=development
PORT=5000

# ─────────────────────────────────────────────────────────────────────────────
# MULTI-TENANT CONFIG
#
# ALLOWED_CLIENTS: comma-separated list of client IDs that are allowed to
# connect. These must exactly match what the frontend sends as 'x-client-id'.
#
# For each client, add a MONGO_URI_{CLIENT_ID_UPPERCASE} entry below.
# The key is built as: MONGO_URI_${clientId.toUpperCase()}
#
# Example: clientId = "newGodamMill" → looks for MONGO_URI_NEWGODAMMILL
# ─────────────────────────────────────────────────────────────────────────────
ALLOWED_CLIENTS=clienta,clientb

# MongoDB URI for each client (local dev example)
# MONGO_URI_CLIENTA=mongodb://localhost:27017/mill
# MONGO_URI_CLIENTA=mongodb+srv://systellexdeveloper_db_user:yNDJYRPur32XIdNZ@cluster0.cbmiqh9.mongodb.net/?appName=Cluster0
MONGO_URI_CLIENTB=mongodb+srv://systellexdeveloper_db_user:IgViahWLnrL4cB5l@millclientb.n91xlns.mongodb.net/millclientb?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────────────────
# PRODUCTION (MongoDB Atlas) — uncomment and fill in:
# ALLOWED_CLIENTS=newGodamMill,otherMill
# MONGO_URI_NEWGODAMMILL=mongodb+srv://user:pass@cluster.mongodb.net/newGodamMill
# MONGO_URI_OTHERMILL=mongodb+srv://user:pass@cluster.mongodb.net/otherMill
# ─────────────────────────────────────────────────────────────────────────────

# CORS (comma-separated for multiple origins)
# CORS_ORIGIN=http://localhost:5173
CORS_ORIGIN=https://muslim-trading.vercel.app

# Logging
LOG_LEVEL=debug
LOG_DIR=logs
